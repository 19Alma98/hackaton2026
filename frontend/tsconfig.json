{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": ["src", "orval.config.ts"],
  "exclude": ["node_modules", "dist"]
}
